DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=quanlydailygas_bot
SESSION_SECRET=change-me-in-production
PORT=3000
NODE_ENV=development
AGENCY_NAME=Đại lý Gas
# URL công khai (magic link + nút Web Telegram). Mở từ điện thoại: bắt buộc HTTPS (ngrok/cloudflare tunnel)
PUBLIC_BASE_URL=http://localhost:3000
# Production (Vercel): NODE_ENV=production, PUBLIC_BASE_URL=https://your-app.vercel.app
# Sau deploy: mở /health một lần để đăng ký Telegram webhook
# WEBHOOK_URL=https://your-domain.com/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET=random-secret-string
ENABLE_CYLINDER_LEDGER=false
# Giảm giá theo gas thừa khi tạo delivery qua API (bot luôn cho nhập gas o)
ENABLE_GAS_SURPLUS=false